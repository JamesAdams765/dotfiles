################################################################################
# AI ASSISTANTS
# GitHub Copilot and Google Gemini wrappers
################################################################################

copilot() {
  # Check if npm is available first
  if ! command -v npm &>/dev/null; then
    echo "❌ npm is required for GitHub Copilot but is not installed"
    echo ""
    echo "Install it with:"
    echo "  Ubuntu/Raspberry Pi: sudo apt-get install -y nodejs npm"
    echo "  macOS: brew install node"
    echo ""
    echo "Or install nvm (Node Version Manager):"
    echo "  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.0/install.sh | bash"
    echo "  nvm install --lts"
    return 1
  fi
  
  # Try to ensure copilot is installed
  if ! _ensure copilot \
    "npm install -g @github/copilot || sudo npm install -g @github/copilot" \
    "npm install -g @github/copilot || sudo npm install -g @github/copilot"; then
    echo "❌ Failed to install GitHub Copilot"
    echo "You can install it manually with:"
    echo "  npm install -g @github/copilot"
    echo "  OR"
    echo "  sudo npm install -g @github/copilot"
    return 1
  fi
  
  if [[ $# -eq 0 ]]; then
    # No arguments - start copilot in interactive mode
    command copilot
  else
    # With arguments - treat as prompt text
    echo "Running: copilot -p \"$*\""
    command copilot -p "$*"
  fi
}

