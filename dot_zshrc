################################################################################
# SYSTEM HEALTH CHECK
# Quickly diagnose shell environment and installed tools
################################################################################

# Check installed tools and identify missing dependencies
health-check() {
  echo "🔍 Checking shell environment...\n"
  
  local tools=("fzf" "curl" "git" "brew" "zoxide" "nvm" "cargo" "go" "node" "npm" "python3" "direnv")
  local missing=()
  
  echo "Installed Tools:"
  for tool in "${tools[@]}"; do
    if command -v "$tool" &>/dev/null; then
      echo "  ✅ $tool"
    else
      echo "  ❌ $tool (not found)"
      missing+=("$tool")
    fi
  done
  
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "\n⚠️  Missing tools (${#missing[@]}):"
    for tool in "${missing[@]}"; do
      echo "  - $tool"
    done
  else
    echo "\n✅ All major tools are installed!"
  fi
  
  # Show OS info
  echo "\nSystem Info:"
  if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "  OS: macOS"
    echo "  Version: $(sw_vers -productVersion)"
  else
    echo "  OS: Linux"
    if command -v lsb_release &>/dev/null; then
      echo "  Distribution: $(lsb_release -d | cut -f2)"
    fi
  fi
}

