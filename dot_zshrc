################################################################################
# DOTFILES MANAGEMENT
# Syncs configuration files to/from GitHub using chezmoi
################################################################################

dotfiles() {
  local chezmoi_dir="$HOME/.local/share/chezmoi"

  # Option 1: Force override - pull from GitHub, discard local changes
  if [[ "$1" == "--force" || "$1" == "-f" ]]; then
    echo "\n⚠️  Force override: discarding local changes and pulling from GitHub...\n"
    git -C "$chezmoi_dir" fetch origin
    git -C "$chezmoi_dir" reset --hard origin/master
    chezmoi apply
    echo "\n  ✓ Dotfiles force-synced from GitHub!\n"
    return 0
  fi

  echo "\n🔄 Syncing dotfiles...\n"

  # Step 1: Pull changes from GitHub first (prevents losing remote changes)
  echo "  ⬇️  Pulling from GitHub..."
  if ! git -C "$chezmoi_dir" pull --no-rebase 2>&1; then
    # Handle merge conflicts if they occur
    local conflicts
    conflicts=($(git -C "$chezmoi_dir" diff --name-only --diff-filter=U 2>/dev/null))

    if [[ ${#conflicts[@]} -gt 0 ]]; then
      echo "\n  ⚠️  Merge conflicts detected in:"
      for f in $conflicts; do echo "      - $f"; done

      # Resolve each conflict interactively
      for f in $conflicts; do
        echo "\n  Conflict in: $f"
        echo "    1) Keep my local changes"
        echo "    2) Use GitHub (remote) changes"
        echo "    3) Open \$EDITOR to resolve manually"
        local choice
        read "choice?  Enter choice (1/2/3): "
        case "$choice" in
          1)
            # Keep local version
            git -C "$chezmoi_dir" checkout --ours -- "$f"
            git -C "$chezmoi_dir" add "$f"
            echo "  ✓ Kept local changes for $f"
            ;;
          2)
            # Accept remote version
            git -C "$chezmoi_dir" checkout --theirs -- "$f"
            git -C "$chezmoi_dir" add "$f"
            echo "  ✓ Used remote changes for $f"
            ;;
          3)
            # Manual resolution
            ${EDITOR:-nano} "$chezmoi_dir/$f"
            git -C "$chezmoi_dir" add "$f"
            echo "  ✓ Manually resolved $f"
            ;;
          *)
            # Default to keeping local
            echo "  ⚠️  Invalid choice — keeping local changes for $f"
            git -C "$chezmoi_dir" checkout --ours -- "$f"
            git -C "$chezmoi_dir" add "$f"
            ;;
        esac
      done

      git -C "$chezmoi_dir" commit -m "sync: resolve merge conflicts" --quiet
      echo "\n  ✓ Conflicts resolved"
    else
      echo "  ✗ Pull failed for an unexpected reason — aborting"
      return 1
    fi
  fi

  # Step 2: Apply pulled changes to actual files (--force overwrites local modifications)
  echo "\n  ✅ Applying changes to local files..."
  chezmoi apply --force

  echo "\n  ✓ Dotfiles synced!\n"
}

# Force override: pull from GitHub and discard all local changes
dotfiles-force() {
  local chezmoi_dir="$HOME/.local/share/chezmoi"
  echo "\n⚠️  Force override: discarding local changes and pulling from GitHub...\n"
  git -C "$chezmoi_dir" fetch origin
  git -C "$chezmoi_dir" reset --hard origin/master
  chezmoi apply
  echo "\n  ✓ Dotfiles force-synced from GitHub!\n"
}

# Force override cloud: push local dotfiles to GitHub, overwriting remote
dotfiles-force-override-cloud() {
  local chezmoi_dir="$HOME/.local/share/chezmoi"
  echo "\n⚠️  Force push: overwriting GitHub with local dotfiles...\n"
  chezmoi re-add
  git -C "$chezmoi_dir" add -A
  git -C "$chezmoi_dir" commit -m "sync: force override cloud with local changes" --quiet
  git -C "$chezmoi_dir" push --force
  echo "\n  ✓ GitHub dotfiles overwritten with local version!\n"
}
