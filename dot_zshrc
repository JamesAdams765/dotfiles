################################################################################
# UPDATE ALL APPLICATIONS
# Updates packages across all installed package managers
################################################################################

update-apps() {
  echo "🔄 Checking for application updates...\n"

  # apt (Debian/Ubuntu/Linux)
  if command -v apt-get &>/dev/null; then
    echo "📦 apt — updating system packages..."
    sudo apt-get update -qq && sudo apt-get upgrade -y
  fi

  # snap (Snap packages on Linux)
  if command -v snap &>/dev/null; then
    echo "\n📦 snap — refreshing snaps..."
    sudo snap refresh
  fi

  # Homebrew (macOS and Linux)
  if command -v brew &>/dev/null; then
    echo "\n📦 brew — updating Homebrew packages..."
    brew update && brew upgrade
  fi

  # pipx (Python app manager)
  if command -v pipx &>/dev/null; then
    echo "\n📦 pipx — upgrading all pipx packages..."
    pipx upgrade-all
  fi

  # cargo (Rust package manager)
  # Note: Requires cargo-update crate to be installed
  if command -v cargo &>/dev/null; then
    if cargo install --list 2>/dev/null | grep -q "^cargo-update"; then
      echo "\n📦 cargo — updating installed crates..."
      cargo install-update -a
    else
      echo "\n📦 cargo — install 'cargo-update' for crate upgrades:"
      echo "     cargo install cargo-update"
    fi
  fi

  # npm (Node.js global packages)
  if command -v npm &>/dev/null; then
    local npm_prefix
    npm_prefix=$(npm config get prefix)
    if [[ -w "$npm_prefix" ]]; then
      echo "\n📦 npm — updating global packages..."
      npm update -g
    else
      echo "\n📦 npm — skipping (requires sudo, configure npm for user permissions)"
    fi
  fi

  # nvm (Node Version Manager)
  # Updates Node.js to the latest LTS version
  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    echo "\n📦 nvm — checking for newer Node.js LTS..."
    source "$NVM_DIR/nvm.sh" && nvm install --lts --reinstall-packages-from=current
  fi

  # go (Go language tools)
  if command -v go &>/dev/null; then
    echo "\n📦 go — updating installed go tools..."
    go install github.com/ajaxray/geek-life@latest 2>/dev/null && echo "  ✓ geek-life"
  fi

  # Nerd Fonts (monospace fonts for terminals and IDEs)
  echo "\n📦 Updating JetBrainsMono Nerd Font..."
  local nf_dir="$HOME/.local/share/fonts"
  local nf_zip="/tmp/JetBrainsMono.zip"
  mkdir -p "$nf_dir"
  
  if curl -fsSL -o "$nf_zip" "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip"; then
    unzip -o -q "$nf_zip" -d "$nf_dir/" && fc-cache -f "$nf_dir" && echo "  ✓ JetBrainsMono Nerd Font updated"
    rm -f "$nf_zip"
  else
    echo "  ⚠️  Download failed (check internet connection)"
  fi

  echo "\n✅ App updates complete!\n"

  # Dotfiles sync (uses chezmoi for dotfile management)
  echo "📦 Dotfiles — syncing from GitHub..."
  if ! command -v chezmoi &>/dev/null; then
    echo "  chezmoi not found — installing..."
    if [[ "$OSTYPE" == "darwin"* ]]; then
      brew install chezmoi
    else
      sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin"
    fi
  fi
  
  if command -v chezmoi &>/dev/null; then
    chezmoi update && echo "  ✓ Dotfiles up to date"
  else
    echo "  ⚠️  chezmoi install failed — skipping dotfiles sync"
  fi

  echo "\n✅ All updates complete!"
}

