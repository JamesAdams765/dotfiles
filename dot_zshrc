# update-apps
update-apps() {
  echo "🔄 Checking for application updates..."

  # apt (Debian/Ubuntu)
  if command -v apt-get &>/dev/null; then
    echo "\n📦 apt — updating system packages..."
    sudo apt-get update -qq && sudo apt-get upgrade -y
  fi

  # snap
  if command -v snap &>/dev/null; then
    echo "\n📦 snap — refreshing snaps..."
    sudo snap refresh
  fi

  # Homebrew (macOS)
  if command -v brew &>/dev/null; then
    echo "\n📦 brew — updating Homebrew packages..."
    brew update && brew upgrade
  fi

  # pipx
  if command -v pipx &>/dev/null; then
    echo "\n📦 pipx — upgrading all pipx packages..."
    pipx upgrade-all
  fi

  # cargo (Rust) — requires cargo-update crate
  if command -v cargo &>/dev/null; then
    if cargo install --list 2>/dev/null | grep -q "^cargo-update"; then
      echo "\n📦 cargo — updating installed crates..."
      cargo install-update -a
    else
      echo "\n📦 cargo — install cargo-update to enable crate upgrades (cargo install cargo-update)"
    fi
  fi

  # npm global packages
  if command -v npm &>/dev/null; then
    local npm_prefix
    npm_prefix=$(npm config get prefix)
    if [[ -w "$npm_prefix" ]]; then
      echo "\n📦 npm — updating global packages..."
      npm update -g
    else
      echo "\n📦 npm — skipping update (system npm, requires sudo)"
    fi
  fi

  # nvm (Node Version Manager) — update to latest LTS
  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    echo "\n📦 nvm — checking for newer Node LTS..."
    source "$NVM_DIR/nvm.sh" && nvm install --lts --reinstall-packages-from=current
  fi

  # go tools
  if command -v go &>/dev/null; then
    echo "\n📦 go — updating installed go tools..."
    go install github.com/ajaxray/geek-life@latest 2>/dev/null && echo "  ✓ geek-life"
  fi

  # Nerd Fonts — update to latest release
  echo "\n📦 nerd-fonts — updating JetBrainsMono Nerd Font..."
  local nf_dir="$HOME/.local/share/fonts"
  local nf_zip="/tmp/JetBrainsMono.zip"
  mkdir -p "$nf_dir"
  if curl -fsSL -o "$nf_zip"       "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip"; then
    unzip -o -q "$nf_zip" -d "$nf_dir/" && fc-cache -f "$nf_dir" && echo "  ✓ JetBrainsMono Nerd Font updated"
    rm -f "$nf_zip"
  else
    echo "  ⚠️  nerd-fonts — download failed (check internet connection)"
  fi

  echo "\n✅ All updates complete!"
}

# journal
journal() {
  local j
  j=$(printf "architecture\nwork\ndev\ndata-platform\n" \
    | fzf --prompt="Select Journal: " --height=~8 --layout=reverse --border --no-sort)
  [[ -n "$j" ]] && _ensure tjournal "brew install tjournal" "cargo install tjournal" && tjournal -j "$HOME/.tjournal/$j/$j.json"
}
alias journal-architecture='tjournal -j ~/.tjournal/architecture/architecture.json'
alias journal-work='tjournal -j ~/.tjournal/work/work.json'
alias journal-dev='tjournal -j ~/.tjournal/dev/dev.json'
alias journal-data-platform='tjournal -j ~/.tjournal/data-platform/data-platform.json'

# tasks
tasks() {
  local db
  db=$(printf "employees\nbroadway\nchurch\nfamily\n" \
    | fzf --prompt="Select Task DB: " --height=~8 --layout=reverse --border --no-sort)
  [[ -n "$db" ]] && _ensure geek-life "go install github.com/ajaxray/geek-life@latest" "go install github.com/ajaxray/geek-life@latest" && geek-life --db-file "$HOME/.geek-life-work-$db.db"
}
alias tasks-employees='geek-life --db-file ~/.geek-life-work-employees.db'
alias tasks-broadway='geek-life --db-file ~/.geek-life-work-broadway.db'
alias tasks-church='geek-life --db-file ~/.geek-life-work-church.db'
alias tasks-family='geek-life --db-file ~/.geek-life-work-family.db'

