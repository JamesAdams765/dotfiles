################################################################################
# AUTO-INSTALL HELPER FUNCTION
# Attempts to install a command if not already available
# Usage: _ensure <command> <macOS_install_cmd> <linux_install_cmd>
# Returns: 0 if command exists or installation succeeds, 1 if installation fails
################################################################################

_ensure() {
  local cmd="$1"
  local macos_cmd="$2"
  local linux_cmd="$3"
  
  # Check if command already exists
  command -v "$cmd" &>/dev/null && return 0
  
  echo "📦 '$cmd' not found — installing..."
  
  # Detect OS and run appropriate install command
  if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS - check if Homebrew is installed
    if ! command -v brew &>/dev/null; then
      echo "❌ Homebrew not found. Please install Homebrew first:"
      echo "   https://brew.sh"
      return 1
    fi
    eval "$macos_cmd"
    local err=$?
    if [[ $err -ne 0 ]]; then
      echo "❌ Installation failed with error code $err"
      return $err
    fi
  else
    # Linux (Ubuntu, Debian, etc.)
    # Always show output to help debug npm issues
    eval "$linux_cmd"
    local err=$?
    if [[ $err -ne 0 ]]; then
      echo "❌ Installation command failed with error code $err"
      return $err
    fi
  fi
  
  # Verify installation succeeded
  if command -v "$cmd" &>/dev/null; then
    echo "✅ Successfully installed '$cmd'"
    return 0
  else
    echo "❌ Failed to install '$cmd' — command not found in PATH after installation"
    echo "   Try checking: npm list -g | grep $cmd"
    echo "   Or install manually: npm install -g @github/copilot"
    return 1
  fi
}

